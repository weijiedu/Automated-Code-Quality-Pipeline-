# GCP Configuration
project_id = "your-gcp-project-id"
region     = "us-west1"
zone       = "us-west1-a"

# GitHub Configuration
# Create a GitHub Personal Access Token with the following scopes:
# - repo (Full control of private repositories)
# - admin:repo_hook (Full control of repository hooks)
github_token       = "ghp_yourGitHubPersonalAccessToken"
github_repo_owner  = "your-github-username-or-org"
github_username    = "your-github-username"

# Jenkins Configuration
jenkins_admin_password = "your-secure-admin-password"

# SonarQube Configuration
# NOTE: This token needs to be created manually after SonarQube is deployed
# 1. Deploy infrastructure first without this value (comment out or use placeholder)
# 2. Access SonarQube UI
# 3. Create a token: User > My Account > Security > Generate Token
# 4. Add the token here and run terraform apply again
sonar_token = "sqa_yourSonarQubeToken"
